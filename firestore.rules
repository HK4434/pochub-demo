// PoCHub Firestore Rules — TEMPORARY OPEN MODE
//
// Bu rules eskisi gibi çalışmaya geri döner.
// Authenticated kullanıcı her şeyi okur/yazar.
//
// NOT: Bu geçici. Düzgün RBAC rules'u sonra yazılacak.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

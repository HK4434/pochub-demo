// PoCHub Firestore Security Rules
// v4.79.1 PATCH - Phase 2.9
//
// PATCH NOTU: v4.79 deploy sonrası admin dashboard'da
// "Missing or insufficient permissions" hatası alındı.
// Bu patch:
// 1. myRole() helper'ı null-safe yapıldı (.get('role', '') ile default değer)
// 2. Server-only koleksiyonlar için admin read kontrolü null-safe
// 3. Genel fallback admin için read-only (bilinmeyen koleksiyon erişiminde admin görebilsin)
// 4. vendor_subscriptions read genişletildi (vendor badge sistemi için)

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function userExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }

    function myRole() {
      return isSignedIn() && userExists(uid()) ? getUser(uid()).get('role', '') : '';
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    function isVendor() {
      return myRole() == 'vendor';
    }

    function isCustomer() {
      return myRole() == 'customer';
    }

    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    function isApprovedVendor() {
      return isVendor() && userExists(uid()) && getUser(uid()).get('vendorStatus', '') == 'approved';
    }

    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function onlyChanging(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function notChanging(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
                    && hasFields(['email', 'role'])
                    && request.resource.data.role in ['vendor', 'customer'];
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && notChanging(['role', 'vendorStatus', 'isSuspendedDueToBilling', 'hasActiveSubscription', 'subscriptionTier']));
      allow delete: if isAdmin();
    }

    match /pochub_packages/{packageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pochub_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /vendor_subscriptions/{vendorId} {
      // PATCH: read genişletildi — vendor badge sistemi için diğer kullanıcılar da görebilmeli
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /subscription_history/{historyId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.vendorId == uid());
      allow create: if isAdmin()
                    || (isVendor()
                        && request.resource.data.vendorId == uid()
                        && request.resource.data.status in ['pending', 'pending_payment']
                        && hasFields(['vendorId', 'packageId', 'action', 'status']));
      allow update, delete: if isAdmin();
    }

    match /poc_requests/{pocId} {
      allow read: if isAdmin()
                  || (isSignedIn()
                      && (resource.data.customerId == uid() || resource.data.vendorId == uid()));
      allow create: if isCustomer()
                    && request.resource.data.customerId == uid()
                    && hasFields(['customerId', 'vendorId', 'productId', 'status']);
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.customerId == uid()
                        && notChanging(['vendorId', 'productId', 'customerId', 'createdAt']))
                    || (isSignedIn()
                        && resource.data.vendorId == uid()
                        && notChanging(['vendorId', 'customerId', 'productId', 'createdAt', 'customerName', 'customerEmail']));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.customerId == uid());
    }

    match /poc_messages/{messageId} {
      allow read: if isSignedIn()
                  && (resource.data.senderId == uid()
                      || resource.data.recipientId == uid()
                      || isAdmin());
      allow create: if isSignedIn()
                    && request.resource.data.senderId == uid()
                    && hasFields(['pocId', 'senderId', 'recipientId', 'content']);
      allow update: if isSignedIn()
                    && resource.data.recipientId == uid()
                    && onlyChanging(['readAt', 'isRead']);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.senderId == uid());
    }

    match /poc_invites/{inviteId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.vendorId == uid())
                  || (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
      allow create: if isApprovedVendor()
                    && request.resource.data.vendorId == uid();
      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.vendorId == uid())
                    || (isSignedIn() && resource.data.customerEmail == request.auth.token.email
                        && onlyChanging(['status', 'acceptedAt', 'declinedAt']));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.vendorId == uid());
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isApprovedVendor()
                    && request.resource.data.vendorId == uid();
      allow update: if isAdmin()
                    || (isApprovedVendor()
                        && resource.data.vendorId == uid()
                        && notChanging(['vendorId', 'createdAt']));
      allow delete: if isAdmin()
                    || (isApprovedVendor() && resource.data.vendorId == uid());
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.recipientId == uid());
      // PATCH: signed-in user kendi notification'ını oluşturabilir (frontend bazı akışlarda yazıyor olabilir)
      allow create: if isSignedIn();
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.recipientId == uid()
                        && onlyChanging(['read', 'readAt']));
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.recipientId == uid());
    }

    match /poc_charges/{chargeId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.vendorId == uid());
      allow write: if isAdmin();
    }

    match /vendor_billing/{vendorId} {
      allow read: if isOwner(vendorId) || isAdmin();
      allow write: if isAdmin();
    }

    match /admin_overrides/{overrideId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.vendorId == uid());
      allow create: if isVendor()
                    && request.resource.data.vendorId == uid()
                    && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /payment_methods/{vendorId} {
      allow read: if isOwner(vendorId) || isAdmin();
      allow write: if isOwner(vendorId) || isAdmin();
    }

    match /pochub_daily_featured/{dateKey} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isApprovedVendor()
                    && request.resource.data.vendorId == uid();
      allow update: if isAdmin()
                    || (isApprovedVendor()
                        && resource.data.vendorId == uid()
                        && notChanging(['vendorId', 'createdAt']));
      allow delete: if isAdmin()
                    || (isApprovedVendor() && resource.data.vendorId == uid());
    }

    match /offers/{offerId} {
      allow read: if isAdmin()
                  || (isSignedIn()
                      && (resource.data.vendorId == uid() || resource.data.customerId == uid()));
      allow create: if isApprovedVendor()
                    && request.resource.data.vendorId == uid();
      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.vendorId == uid()
                        && notChanging(['vendorId', 'customerId', 'createdAt']))
                    || (isSignedIn() && resource.data.customerId == uid()
                        && onlyChanging(['customerResponse', 'respondedAt', 'status']));
      allow delete: if isAdmin();
    }

    match /poc_conversations/{convId} {
      allow read: if isAdmin()
                  || (isSignedIn()
                      && (resource.data.customerId == uid() || resource.data.vendorId == uid()));
      allow create: if isSignedIn()
                    && (request.resource.data.customerId == uid() || request.resource.data.vendorId == uid());
      allow update: if isAdmin()
                    || (isSignedIn()
                        && (resource.data.customerId == uid() || resource.data.vendorId == uid())
                        && notChanging(['customerId', 'vendorId', 'pocId', 'createdAt']));
      allow delete: if isAdmin();
    }

    // SERVER-WRITE-ONLY
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /cron_runs/{runId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /email_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /weekly_digests/{digestId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notification_dedup/{dedupId} {
      allow read, write: if false;
    }

    // PATCH: GENEL FALLBACK — admin için read-only (debug + yeni koleksiyon erişimi için)
    // Bu kural sayesinde rules'da unutulan bir koleksiyon olsa bile admin görebilir.
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

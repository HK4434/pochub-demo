// PoCHub Firestore Rules — v4.85.1 (patch)
//
// DÜZELTME: Önceki versiyon "request.auth != null" zorunlu yapıyordu, ama logout
// kullanıcıları (anonim ziyaretçi) ana sayfada featured carousel ve etkinlikleri
// göremiyordu. Bu network effect stratejine ters.
//
// YENİ MANTIK:
//   - Public okuma (events, products, vendors profili, packages, config, featured)
//   - Logout iken bunlar görünebilir
//   - Yazma sadece login isteyecek
//   - Server-write-only koleksiyonlar (audit_log vs.) sadece admin okur
//
// ROLLBACK: Firebase Console -> Firestore -> Rules -> Version history -> Restore

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Yardımcı: kullanıcı admin mi?
    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // ═══════════════════════════════════════════════════════════════
    // SERVER-WRITE-ONLY (Functions admin SDK rules bypass eder)
    // ═══════════════════════════════════════════════════════════════

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /cron_runs/{runId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /email_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /weekly_digests/{digestId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notification_dedup/{dedupId} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // FALLBACK — Public read, authenticated write
    //
    // Public okuma: anonim ziyaretçi de ana sayfa/katalog görebilir
    // Yazma: sadece login olmuş kullanıcı
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read: if true;                        // Public read (logout dahil)
      allow write: if request.auth != null;       // Yazma için login zorunlu
    }
  }
}
